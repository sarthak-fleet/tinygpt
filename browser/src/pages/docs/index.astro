---
/**
 * /docs/ — auto-generated landing page.
 *
 * Walks src/content/docs/ via import.meta.glob, groups by top-level
 * directory, and emits one card per markdown file. Each card's blurb
 * is taken from the doc's frontmatter `description` if present, else
 * from the first paragraph after the title heading.
 *
 * Adding a new doc → just drop a .md under docs/ and rebuild; the
 * landing page picks it up automatically. No wrapper page needed.
 */
import Default from "../../layouts/Default.astro";

type MdModule = {
  frontmatter?: {
    title?: string;
    description?: string;
  };
  rawContent?: () => string;
};

const docs = import.meta.glob<MdModule>("../../content/docs/**/*.md", {
  eager: true,
});

type DocEntry = {
  slug: string;       // url path after /docs/
  title: string;
  blurb: string;
  group: string;      // category for grouping
};

// Acronyms / abbreviations that should stay uppercased when humanizing
// a slug. Maps lower-case match → preferred display.
const ACRONYMS: Record<string, string> = {
  dpo: "DPO",
  sft: "SFT",
  mtp: "MTP",
  moe: "MoE",
  fa2: "FA2",
  lora: "LoRA",
  qa: "Q&A",
  qlora: "QLoRA",
  hqq: "HQQ",
  awq: "AWQ",
  gptq: "GPTQ",
  yoco: "YOCO",
  alibi: "ALiBi",
  rope: "RoPE",
  bpe: "BPE",
  hf: "HF",
  webgpu: "WebGPU",
  wasm: "WASM",
  wgsl: "WGSL",
};

function humanize(s: string): string {
  return s
    .replace(/[_-]+/g, " ")
    // Split "tier1" → "tier 1", "phase9" → "phase 9".
    .replace(/([a-zA-Z])(\d)/g, "$1 $2")
    .split(" ")
    .map((w) => ACRONYMS[w.toLowerCase()] ?? w.charAt(0).toUpperCase() + w.slice(1))
    .join(" ");
}

// Pull a one-line blurb from raw markdown — first non-heading narrative
// paragraph, trimmed to ~160 chars. Falls back to the title if none found.
function deriveBlurb(raw: string, fallback: string): string {
  const lines = raw.split(/\r?\n/);
  const paragraphs: string[] = [];
  let buf: string[] = [];
  let inCodeFence = false;

  const flush = () => {
    if (buf.length) {
      paragraphs.push(buf.join(" ").trim());
      buf = [];
    }
  };

  for (const line of lines) {
    const t = line.trim();
    if (t.startsWith("```")) {
      inCodeFence = !inCodeFence;
      flush();
      continue;
    }
    if (inCodeFence) continue;
    if (line.startsWith("#")) {
      flush();
      continue;
    }
    if (t === "") {
      flush();
      continue;
    }
    // Skip non-narrative lines (bullets, tables, quotes) outright. If a
    // paragraph is BUILT from these we don't want it — just continue.
    if (t.startsWith("|") || t.startsWith("-") || t.startsWith("*") || t.startsWith(">") || /^\d+\./.test(t)) {
      flush();
      continue;
    }
    buf.push(t);
  }
  flush();

  const first = paragraphs.find((p) => p.length > 30);
  if (!first) return fallback;
  // Strip markdown link / inline-code / bold-italic syntax.
  const cleaned = first
    .replace(/\[([^\]]+)\]\([^)]+\)/g, "$1")
    .replace(/`([^`]+)`/g, "$1")
    .replace(/\*\*([^*]+)\*\*/g, "$1")
    .replace(/\*([^*]+)\*/g, "$1")
    .replace(/\s+/g, " ")
    .trim();
  return cleaned.length > 200 ? cleaned.slice(0, 197) + "…" : cleaned;
}

const entries: DocEntry[] = Object.entries(docs).map(([path, mod]) => {
  const rel = path.replace(/^.*\/content\/docs\//, "").replace(/\.md$/, "");
  const slug = rel.replace(/\/index$/, "");
  const fm = mod.frontmatter ?? {};
  const parts = rel.split("/");
  const last = parts[parts.length - 1];
  const title = fm.title ?? humanize(last === "index" ? parts[parts.length - 2] ?? "Overview" : last);

  // Group by top-level directory; root files go in "Project" (renamed below).
  const group = parts.length > 1 ? parts[0] : "Top-level";

  const rawFn = (mod as any).rawContent;
  const raw = typeof rawFn === "function" ? rawFn() : "";
  const blurb = fm.description ?? deriveBlurb(raw, title);

  return { slug, title, blurb, group };
});

// Sort entries within each group: index/overview first, then alphabetical.
entries.sort((a, b) => {
  if (a.group !== b.group) return a.group.localeCompare(b.group);
  // Bring directory-index pages to the top of their group.
  const aIdx = a.slug.endsWith("/index") || !a.slug.includes("/");
  const bIdx = b.slug.endsWith("/index") || !b.slug.includes("/");
  if (aIdx !== bIdx) return aIdx ? -1 : 1;
  return a.title.localeCompare(b.title);
});

// Group label friendly names — keep stable insertion order.
const GROUP_LABEL: Record<string, string> = {
  "Top-level": "Core docs",
  roadmap: "Roadmap (single-machine plan)",
  training: "Training pipeline",
  research: "Recent benchmark research",
  archive: "Archive (older / superseded)",
};

const GROUP_ORDER = ["Top-level", "roadmap", "training", "research", "archive"];

// Bucket entries by group.
const grouped = new Map<string, DocEntry[]>();
for (const e of entries) {
  if (!grouped.has(e.group)) grouped.set(e.group, []);
  grouped.get(e.group)!.push(e);
}

// Ordered list of [groupKey, label, entries] tuples for the template.
const sections = GROUP_ORDER
  .filter((g) => grouped.has(g))
  .map((g) => ({
    key: g,
    label: GROUP_LABEL[g] ?? humanize(g),
    items: grouped.get(g)!,
  }));

// Anything in an unexpected group (future folders): append.
for (const [g, items] of grouped) {
  if (!GROUP_ORDER.includes(g)) {
    sections.push({ key: g, label: GROUP_LABEL[g] ?? humanize(g), items });
  }
}

const totalCount = entries.length;

const layoutProps = {
  title: "TinyGPT — documentation library",
  description: `Every doc in the repo, ${totalCount} files in total — lessons, retrospectives, the full roadmap, training pipeline, interpretability, performance research, and archived material.`,
  ogType: "article" as const,
  ogTitle: "TinyGPT — documentation library",
  ogDescription: "Every doc in the repo: lessons, retrospectives, roadmap, training pipeline, perf research, and archived material.",
  themeColor: "#0a0c10",
};

const style = `
  :root {
    --bg: #0a0c10;
    --panel: #11141a;
    --line: #232733;
    --fg: #e7e8ea;
    --muted: #c8cbd4;
    --faint: #787d88;
    --accent: #48e5c2;
    --accent-dim: #2a8a78;
    --font-sans: "Geist", ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    --font-mono: "Geist Mono", ui-monospace, "SF Mono", Monaco, "Cascadia Code", "Roboto Mono", monospace;
  }
  html, body {
    background: var(--bg); color: var(--fg);
    font: 16px/1.7 var(--font-sans);
    margin: 0; padding: 0;
    -webkit-font-smoothing: antialiased;
  }
  .wrap { max-width: 880px; margin: 0 auto; padding: 56px 24px 96px; }
  .eyebrow {
    font: 500 11px/1 var(--font-mono);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 18px;
    display: flex; gap: 8px; flex-wrap: wrap;
  }
  .eyebrow a { color: var(--accent); text-decoration: none; border-bottom: 1px dashed transparent; transition: border-color 0.2s; }
  .eyebrow a:hover { border-bottom-color: var(--accent); }
  .eyebrow .sep { color: var(--faint); }

  h1 { font: 600 36px/1.2 var(--font-sans); color: var(--fg); margin: 0 0 16px; letter-spacing: -0.01em; }
  .lede { color: var(--muted); font-size: 17px; line-height: 1.6; margin: 0 0 40px; max-width: 700px; }

  h2.section {
    font: 600 16px/1.3 var(--font-sans);
    color: var(--fg);
    margin: 36px 0 14px;
    letter-spacing: 0.005em;
    padding-bottom: 8px;
    border-bottom: 1px solid var(--line);
    display: flex; justify-content: space-between; align-items: baseline;
  }
  h2.section .count {
    font: 500 11px/1 var(--font-mono);
    color: var(--faint);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .doc-grid { display: grid; grid-template-columns: 1fr; gap: 10px; }

  .doc-card {
    display: block;
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: 10px;
    padding: 16px 20px;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.2s, background 0.2s, transform 0.2s;
  }
  .doc-card:hover {
    border-color: var(--accent-dim);
    background: rgba(72, 229, 194, 0.03);
    transform: translateY(-1px);
  }
  .doc-card-head {
    display: flex; justify-content: space-between; align-items: baseline;
    gap: 16px; margin-bottom: 6px;
  }
  .doc-card-title {
    font: 600 15.5px/1.3 var(--font-sans);
    color: var(--fg);
  }
  .doc-card-tag {
    font: 500 10px/1 var(--font-mono);
    text-transform: lowercase;
    letter-spacing: 0.06em;
    color: var(--accent);
    background: rgba(72, 229, 194, 0.06);
    border: 1px solid rgba(72, 229, 194, 0.18);
    padding: 3px 7px;
    border-radius: 999px;
    flex-shrink: 0;
    word-break: break-all;
  }
  .doc-card-blurb {
    color: var(--muted);
    font-size: 13.5px;
    line-height: 1.55;
    margin: 0;
  }

  .foot {
    margin-top: 56px;
    padding-top: 22px;
    border-top: 1px solid var(--line);
    color: var(--faint);
    font: 13px/1.6 var(--font-mono);
    display: flex; gap: 12px; flex-wrap: wrap;
  }
  .foot a {
    color: var(--accent);
    text-decoration: none;
    border-bottom: 1px dashed var(--accent-dim);
  }
  .foot a:hover { border-bottom-color: var(--accent); }
`;
---

<Default {...layoutProps}>
  <style is:global slot="head" set:html={style}></style>
  <div class="wrap">
    <div class="eyebrow">
      <a href="/">← TinyGPT</a>
      <span class="sep">·</span>
      <a href="/devlog">devlog</a>
      <span class="sep">·</span>
      <a href="/roadmap">roadmap</a>
      <span class="sep">·</span>
      <a href="/speedup">speedup</a>
    </div>

    <h1>Documentation</h1>
    <p class="lede">
      Every markdown file in <code>docs/</code> rendered as a page —
      {totalCount} docs in total. The markdown source lives in the repo at
      <a href="https://github.com/sarthak-fleet/tinygpt/tree/main/docs" target="_blank" rel="noopener">github.com/sarthak-fleet/tinygpt/tree/main/docs</a>.
      A "where things moved" table for anything you can't find lives at
      <a href="/docs/MAP">/docs/MAP</a>.
    </p>

    {sections.map((s) => (
      <>
        <h2 class="section">
          <span>{s.label}</span>
          <span class="count">{s.items.length} files</span>
        </h2>
        <div class="doc-grid">
          {s.items.map((d) => (
            <a class="doc-card" href={`/docs/${d.slug}`}>
              <div class="doc-card-head">
                <span class="doc-card-title">{d.title}</span>
                <span class="doc-card-tag">{d.slug}</span>
              </div>
              <p class="doc-card-blurb">{d.blurb}</p>
            </a>
          ))}
        </div>
      </>
    ))}

    <div class="foot">
      <span>TinyGPT</span>
      <span class="sep">·</span>
      <a href="https://github.com/sarthak-fleet/tinygpt">repo ↗</a>
      <span class="sep">·</span>
      <a href="https://github.com/sarthak-fleet/tinygpt/tree/main/docs">raw markdown ↗</a>
    </div>
  </div>
</Default>
