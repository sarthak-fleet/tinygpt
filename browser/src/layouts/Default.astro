---
/**
 * Default.astro — shared shell for every page.
 *
 * Centralizes the bits that genuinely repeat across all five routes:
 *   - <!doctype>, <html lang>, charset, viewport
 *   - favicon, theme-color
 *   - Geist + Geist Mono fonts (self-hosted via @fontsource-variable)
 *   - OG/Twitter meta with sensible defaults overridable per page
 *
 * Page-specific styles still live inside each page's own <style is:global>
 * block — the CSS-variable palette varies between the playground (--base
 * #08090a) and the devlog/speedup pages (--bg #0a0c10), and the cascade
 * relies on global selectors that Astro's per-component scoping would
 * break. Keeping styles on the page preserves the existing visual design
 * with zero refactor risk.
 *
 * Fonts are now self-hosted via @fontsource-variable to drop the
 * fonts.googleapis.com CSS chain from the LCP path. The woff2 files ship
 * from the same origin as the HTML, so no preconnect/preload of an
 * external CDN is required. Browsers only fetch the woff2 when CSS
 * actually references the family — so the loadFonts prop is preserved
 * for API compat but is effectively a no-op for self-hosted fonts
 * (pages that don't reference "Geist Variable" in CSS won't pull the
 * file).
 */
import "@fontsource-variable/geist";
import "@fontsource-variable/geist-mono";

export interface Props {
  title: string;
  description: string;
  ogTitle?: string;
  ogDescription?: string;
  ogType?: "website" | "article";
  ogUrl?: string;
  twitterTitle?: string;
  twitterDescription?: string;
  themeColor?: string;
  /**
   * Retained for API compat with existing pages (training-dashboard,
   * speedup, devlog, webgpu-test pass false). Now a no-op: self-hosted
   * woff2 files are only fetched if CSS actually references the family,
   * so opting out happens implicitly via not using the font in styles.
   */
  loadFonts?: boolean;
}

const {
  title,
  description,
  ogTitle,
  ogDescription,
  ogType = "website",
  ogUrl,
  twitterTitle,
  twitterDescription,
  themeColor = "#08090a",
  loadFonts: _loadFonts = true,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="theme-color" content={themeColor} />
    <meta name="description" content={description} />
    <title>{title}</title>

    <!-- Open Graph / Twitter card -->
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={ogTitle ?? title} />
    <meta property="og:description" content={ogDescription ?? description} />
    <meta property="og:image" content="/og-image.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    {ogUrl && <meta property="og:url" content={ogUrl} />}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={twitterTitle ?? ogTitle ?? title} />
    <meta name="twitter:description" content={twitterDescription ?? ogDescription ?? description} />
    <meta name="twitter:image" content="/og-image.png" />

    <!-- Preload the gallery manifest so the demo banner doesn't pop in
         late on a cold load (was waiting for the JS bundle to evaluate
         before kicking off the fetch). 2 KB JSON, tiny win, big perceived
         smoothness improvement on first paint. -->
    <link rel="preload" href="/gallery/manifest.json" as="fetch" crossorigin="anonymous" />

    <slot name="head" />

    <!-- Pre-paint layout-shift guard. Reads localStorage SYNCHRONOUSLY before
         the body parses, and adds classes on <html> that CSS uses to hide
         elements in their resting state. Without this, hidden-by-default
         elements (intro card, demo banner) would flash visible after JS ran
         and shove content below them around on every page load. -->
    <script is:inline>
      (function () {
        try {
          const html = document.documentElement;
          if (localStorage.getItem("tinygpt.introDismissed") === "1") {
            html.classList.add("intro-dismissed");
          }
        } catch (_) { /* private mode / disabled storage — accept the one-time shift */ }
      })();
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>
